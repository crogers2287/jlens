{
  "_doc": "M20 explicit-opt-in fixture-grounded regeneration over M19 retrieval results. Full fixture context and grounded output stay transient/local and are never persisted.",
  "endpoint": {
    "base_url": "http://localhost:9069/v1",
    "model": "agents-a1",
    "api_key": "not-needed",
    "timeout_s": 180
  },
  "mode": "live",
  "tasks": "data/prompts/agents_a1_m19_batch.jsonl",
  "runtime_records": "reports/shadow/private/agents_a1_m19_run_local.jsonl",
  "action_results": "reports/shadow/private/agents_a1_m19_action_results_local.jsonl",
  "retrieval_fixture": "reports/shadow/private/m20_grounded_fixture_local.json",
  "grounded": {
    "enabled": true,
    "results_log": "reports/shadow/private/agents_a1_m20_grounded_results_local.jsonl",
    "summary_out": "reports/outcomes/agents_a1_m20_grounded_summary.json",
    "review_summary_out": "reports/outcomes/agents_a1_m20_review_summary.json"
  }
}
