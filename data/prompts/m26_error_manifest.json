 "m27_frozen_protocol": {
  "classifier_family": "train-standardized nearest centroid",
  "standardization": "train mean and sample standard deviation only",
  "distance": "squared_euclidean",
  "tie_break": "lexicographic (fail before pass)",
  "baselines_required": [
   "majority_class",
   "metadata_only",
   "logits_only",
   "router_only",
   "router_plus_logits",
   "full_telemetry"
  ],
  "metrics": [
   "accuracy",
   "balanced_accuracy",
   "macro_f1",
   "per_class_precision_recall_f1",
   "accuracy_bootstrap_95pct"
  ],
  "bootstrap_iterations": 2000,
  "bootstrap_seed_prefix": "m27:frozen",
  "holdout_evaluated_once": true,
  "no_refit_or_threshold_tuning_after_holdout": true,
  "template_leakage_control": "train and holdout share the single declared prompt template by design; operand tuples are unique, so no task instance repeats; metadata_only baseline quantifies the difficulty-band shortcut that telemetry must beat"
 },
 "m28_frozen_protocol": {
  "ablations": [
   "single_feature",
   "leave_one_out_from_full_telemetry"
  ],
  "classifier_family": "same frozen nearest centroid protocol as M27",
  "calibration_score": "softmax over negative squared centroid distances taken as pseudo-probability of fail",
  "calibration_bins": "4 equal-count holdout bins",
  "calibration_metrics": [
   "expected_calibration_error",
   "reliability_curve"
  ],
  "false_positive_negative_analysis": "aggregate by band and split only",
  "threshold_status": "candidate-only; never production",
  "verifier_contradiction_feature": "excluded by design: the verifier defines the label, so using its signal as input would leak labels"
 },
 "privacy": {
  "public_artifacts": "aggregate counts, band definitions, metrics only",
  "private_artifacts": "generated operand tuples/prompts, captures, outputs, per-task labels and predictions stay in gitignored locations",
