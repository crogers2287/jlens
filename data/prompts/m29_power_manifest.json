{
 "milestone": "M29",
 "schema_version": 1,
 "selection_status": "predeclared_before_m29_task_generation",
 "research_question": "Does internal telemetry add statistically meaningful predictive value over difficulty-band metadata for within-category objective error prediction, at a sample size that can detect the increment?",
 "relation_to_prior_milestones": {
  "m27_holdout_reused_as_decision_target": false,
  "window_entropy_set_provenance": "motivated by the M28 ablation on the spent M27 holdout; tested here on entirely new predeclared data"
 },
