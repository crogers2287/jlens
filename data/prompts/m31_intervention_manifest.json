 "frozen_score": {
  "source": "M30 full_telemetry nearest centroid",
  "reinstantiation": "deterministically refit from the private M30 train records with the M30 manifest feature definitions; no M31 fitting",
  "verification": "the refit model's predictions on the private M30 holdout must exactly reproduce the confusion matrix published in hf_m30_decisive_increment_evaluation",
  "threshold_fail_probability": 0.5,
  "threshold_source": "M30 validation grid (frozen; candidate-only)",
  "no_refit_or_threshold_change": true
 },
 "decode_protocols": {
  "original": {
   "decode": "greedy",
   "decode_cap_tokens": 64,
   "chat_template": true,
   "router_only_capture": true,
   "dtype": "bf16"
  },
  "retry": {
   "decode": "temperature_sampled",
   "temperature": 0.7,
   "decode_cap_tokens": 64,
   "chat_template": true,
   "router_only_capture": true,
   "dtype": "bf16",
   "per_task_seed_rule": "64-bit evidence-hash integer of 'm31-retry:' + task_id seeds a dedicated torch generator",
   "samples_per_task": 1
  },
  "greedy_path_unchanged": true
 },
 "label_rule": {
  "labeler": "math_checker deterministic verifier",
  "applies_to": "original and retry outputs independently",
  "classes": [
   "pass",
   "fail"
  ],
  "undecided_handling": "tasks with an undecided original or retry verdict are excluded from all policies and reported as aggregate counts"
 },
 "policies": {
  "semantics": "replace-on-retry: the final output is the retry output for retried tasks, else the original; no policy may consult any verifier label",
  "no_retry": "original outputs for all tasks",
  "always_retry": "retry outputs for all tasks",
  "random_retry": "fixed-seed random.Random('m31:random-retry') subset of task ids, size matched to the telemetry trigger count",
  "telemetry_triggered": "retry iff frozen p(fail) >= 0.5 on the original decode's telemetry"
 },
 "metrics_protocol": {
  "per_policy": [
   "verified_success_rate",
   "retries_used",
   "false_alarm_count",
   "errors_rescued",
   "errors_introduced"
  ],
  "paired_deltas": [
   [
    "telemetry_triggered",
    "no_retry"
   ],
   [
    "telemetry_triggered",
    "random_retry"
   ],
   [
    "always_retry",
    "no_retry"
   ],
   [
    "random_retry",
    "no_retry"
   ]
  ],
  "method": "paired bootstrap over task rows, 2000 iterations, fixed seed m31:delta:<a>-vs-<b>, 95% intervals for the success-rate difference",
  "classification_rule": {
   "useful": "telemetry_triggered minus no_retry success CI lower bound > 0 AND telemetry_triggered minus random_retry success CI lower bound > 0",
   "harmful": "telemetry_triggered minus no_retry success CI upper bound < 0",
   "not_established": "otherwise"
  }
 },
 "recovery_traces": {
  "criterion": "verified wrong-to-right rescues under the telemetry_triggered policy only",
  "storage": "private gitignored JSONL",
  "public_reporting": "aggregate counts and schema description only"
 },
 "privacy": {
  "public_artifacts": "aggregate counts, metrics, intervals only",
  "private_artifacts": "operand tuples/prompts, captures, outputs, per-task labels/predictions/triggers, and recovery traces stay gitignored"
 },
 "candidate_only": true,
 "production_gated": true
}
