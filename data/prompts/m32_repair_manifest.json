 "frozen_trigger": {
  "source": "M30 full_telemetry nearest centroid",
  "reinstantiation": "deterministic refit from private M30 train records; must exactly reproduce the published M30 holdout confusion matrix",
  "threshold_fail_probability": 0.5,
  "scored_input": "original greedy decode telemetry only",
  "no_m32_labels_affect_triggering": true
 },
 "decode_protocols": {
  "original": {
   "decode": "greedy",
   "decode_cap_tokens": 64,
   "chat_template": true,
   "router_only_capture": true,
   "dtype": "bf16"
  },
  "greedy_path_unchanged": true
 },
 "verifier_conditioning_rule": "structured repair operators are defined as verifier-conditioned: a policy that attempts repair on a task first checks the original with the deterministic verifier; if the original passes it is kept (cost: one verifier call) and no candidates are consumed. Repair candidates are therefore generated once, for originally-failing tasks only, and shared identically by every policy and selector. The truthful verifier fact is what checker-guided prompts require; no repair prompt may ever contain the correct answer.",
 "repair_operators": {
  "candidate_order_frozen": [
   "independent_deliberate",
   "checker_guided_repair",
   "diagnose_then_repair"
  ],
  "resample_t07": {
   "role": "M31 baseline operator (not part of the structured bundle)",
   "decode": "temperature_sampled",
   "temperature": 0.7,
   "seed_prefix": "m32-resample",
   "decode_cap_tokens": 64,
   "prompt": "original task prompt unchanged",
   "generated_for": "all 384 tasks (exact M31 replication semantics)"
  },
  "independent_deliberate": {
   "decode": "greedy",
   "decode_cap_tokens": 128,
   "generated_for": "originally-failing tasks",
   "prompt_template": "Compute {a} x {b} using long multiplication. Break {b} into parts, write each partial product on its own line, add the partial products carefully, and end with the line 'Answer: <number>'.",
   "excludes_original_answer": true
  },
  "checker_guided_repair": {
   "decode": "greedy",
   "decode_cap_tokens": 128,
   "generated_for": "originally-failing tasks",
   "prompt_template": "You previously answered this problem: What is {a} x {b}? Your previous final answer was {original_answer}. An automatic checker determined that answer is incorrect. Do not repeat it. Find the likely arithmetic mistake, recompute using a different method (long multiplication with partial products), and end with the line 'Answer: <number>'.",
   "reveals_correct_answer": false
  },
  "diagnose_then_repair": {
   "stage_a": {
    "decode": "greedy",
    "decode_cap_tokens": 64,
    "prompt_template": "A student answered the problem 'What is {a} x {b}?' with {original_answer}, which an automatic checker marked incorrect. In two or three short sentences, state the most likely arithmetic mistakes (carrying errors, misaligned partial products, dropped digits) and give a brief verification plan. Do not compute the final answer."
   },
   "stage_b": {
    "decode": "greedy",
    "decode_cap_tokens": 128,
    "prompt_template": "Problem: What is {a} x {b}?\nA reviewer's diagnosis of a previous failed attempt:\n{diagnosis}\nFollowing this plan, recompute the answer step by step with partial products and end with the line 'Answer: <number>'."
   },
   "generated_for": "originally-failing tasks",
   "stage_a_output_private": true
  },
  "tool_upper_bound": {
   "definition": "deterministic trusted integer multiplication",
   "role": "upper-bound/product reference only; never mixed into model-generated rescue counts or H1/H2"
  },
  "no_weight_updates": true
 },
 "selectors": {
  "verifier_first_pass_bundle": {
   "role": "primary structured bundle",
   "semantics": "evaluate structured candidates in the frozen order; select the first verifier-passing candidate; keep the original when none passes; replacing a verifier-passing original with a failing candidate is a stop condition"
  },
  "telemetry_rerank_bundle": {
   "role": "secondary, CLUE-inspired",
   "semantics": "rank the three structured candidates by the frozen M30 p(fail) on each candidate's own telemetry, ascending, without consulting candidate labels; select the lowest-risk candidate; report verifier pass rate versus first-candidate and majority baselines",
   "distribution_shift_caveat": "repair prompts differ from the M30 training prompt family; reported as a known limitation"
  },
  "majority_bundle": {
   "role": "secondary self-consistency baseline",
   "semantics": "numeric majority over the final numbers of the three structured candidates plus resample_t07; ties break to the candidate earliest in the frozen order (resample last); no verifier consultation"
  }
 },
 "policies": {
  "no_repair": "original outputs for all tasks",
  "always_structured_bundle": "attempt verifier-first bundle on all tasks",
  "random_trigger_structured_bundle": "attempt bundle on a fixed-seed random.Random('m32:random-trigger') subset of task ids, size matched to the telemetry trigger count",
  "telemetry_trigger_structured_bundle": "attempt bundle iff frozen p(fail) >= 0.5 on original telemetry",
  "telemetry_trigger_resample_only": "exact M31 semantics: on triggered tasks replace the original with the resample candidate unconditionally (no verifier)",
  "telemetry_trigger_tool_upper_bound": "on triggered tasks replace with the tool result; ceiling only",
  "equal_access_rule": "all verifier-guided arms and their matched controls receive identical verifier access and the identical shared candidate captures"
 },
 "hypotheses": {
  "h1_repair_improvement": {
   "population": "correctly-triggered original failures (triggered AND original verdict fail)",
   "comparison": "verifier-first structured-bundle rescue rate minus resample_t07 candidate rescue rate, paired per task",
   "classification": {
    "repair_improved": "paired 95% CI strictly above zero",
    "repair_worse": "paired 95% CI strictly below zero",
    "repair_not_established": "otherwise"
   },
   "bootstrap_seed": "m32:h1:bundle-vs-resample"
  },
  "h2_policy_usefulness": {
   "comparisons": [
    [
     "telemetry_trigger_structured_bundle",
     "no_repair"
    ],
    [
     "telemetry_trigger_structured_bundle",
     "random_trigger_structured_bundle"
    ]
   ],
   "classification": {
    "useful": "both paired success-delta 95% CIs strictly above zero",
    "harmful": "delta versus no_repair 95% CI strictly below zero",
    "not_established": "otherwise"
   },
   "bootstrap_seed_prefix": "m32:h2"
  },
  "tool_upper_bound_excluded_from_h1_h2": true,
  "bootstrap_iterations": 2000
 },
 "metrics_required": [
  "original pass/fail/undecided/cap counts",
  "trigger count/rate/precision/recall/false alarms",
  "per-operator candidate pass rate",
  "rescues and right-to-wrong introductions per policy",
  "final verified success by policy",
  "candidates and decode tokens used per policy; tokens per rescue",
  "paired bootstrap CIs for preregistered deltas",
  "candidate rescue overlap (unique vs shared)",
  "telemetry-rerank selection accuracy vs candidate labels",
  "tool upper-bound ceiling",
  "private recovery trace count"
 ],
