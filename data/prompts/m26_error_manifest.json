{
 "milestone": "M26",
 "schema_version": 1,
 "selection_status": "predeclared_before_m26_task_generation",
 "research_question": "Can internal Qwen telemetry predict objective pass/fail arithmetic errors inside one fixed task category where prompt family and action applicability are held constant?",
 "task_category": "integer_arithmetic_single_expression",
 "prompt_template": "What is {a} {op} {b}? Reply with the final number only.",
 "prompt_family_constant": true,
 "action_applicability": {
  "rule": "every task carries task_category=math plus a safe arithmetic expression, so the existing supervisor/router must plan checker_needed for all 96 tasks",
  "expected_action_type": "checker_needed",
  "constant_across_all_tasks": true,
  "violation_handling": "stop milestone and report; do not relabel"
 },
 "generation": {
  "seed": "m26-objective-error-v1",
  "algorithm": "per band, draw unique (a, b) operand tuples from random.Random(seed + ':' + band_id) uniform in the declared inclusive ranges, rejecting duplicate tuples, until n_tasks tuples exist; assign tuples to the predeclared task_ids in draw order",
  "no_posthoc_selection": true,
  "all_generated_tasks_retained": true,
  "operand_uniqueness_scope": "within band"
 },
 "label_rule": {
  "labeler": "math_checker deterministic verifier",
  "input": "same-run captured greedy decode output only",
  "truth_source": "safe evaluation of the task expression",
  "classes": [
   "pass",
   "fail"
  ],
  "undecided_handling": "undecided verdicts are excluded from modeling and reported as aggregate counts",
  "human_selection": "none"
 },
 "decode_protocol": {
  "decode": "greedy",
  "decode_cap_tokens": 64,
  "chat_template": true,
  "router_only_capture": true,
  "hidden_capture": "disabled",
  "backend_top_k": 5,
  "dtype": "bf16",
  "architecture_family": "qwen2_moe",
  "hardware_plan": "two_24gib_nvidia_gpus_bf16"
 },
