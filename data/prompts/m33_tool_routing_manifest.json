 "frozen_trigger": {
  "source": "M30 full_telemetry nearest centroid",
  "reinstantiation": "deterministic refit from private M30 train records; must exactly reproduce the published M30 holdout confusion matrix",
  "threshold_fail_probability": 0.5,
  "scored_input": "original greedy decode telemetry only",
  "no_m32_labels_affect_triggering": true
 },
 "decode_protocols": {
  "original": {
   "decode": "greedy",
   "decode_cap_tokens": 64,
   "chat_template": true,
   "router_only_capture": true,
   "dtype": "bf16"
  },
  "greedy_path_unchanged": true,
  "no_repair_or_resample_decodes": true
 },
 "tool": {
  "kind": "deterministic_integer_evaluator",
  "input": "the task's own predeclared expression, never model output",
  "verifier_conditioning": "tool output passes the same verifier as model output",
  "decode_tokens_per_invocation": 0,
  "compute_unit": "tool invocation count, reported per policy"
 },
 "policies": {
  "no_repair": "original outputs for all tasks",
  "tool_on_every_task": "verifier-first tool answer on every task; a passing original is never replaced",
  "random_trigger_tool": "verifier-first tool answer on a fixed-seed random.Random('m33:random-trigger') subset of task ids, size matched to the telemetry trigger count",
  "telemetry_trigger_tool": "verifier-first tool answer iff frozen p(fail) >= 0.5 on original telemetry"
 },
 "hypotheses": {
  "h1_routing_usefulness": {
   "population": "all 384 tasks",
   "comparisons": [
    [
     "telemetry_trigger_tool",
     "no_repair"
    ],
    [
     "telemetry_trigger_tool",
     "random_trigger_tool"
    ]
   ],
   "classification": {
    "useful": "both paired 95% success-delta CIs strictly above zero",
    "harmful": "either upper bound strictly below zero",
    "not_established": "otherwise"
   },
   "bootstrap_seed_prefix": "m33:h1",
   "bootstrap_iterations": 2000
  },
  "h2_routing_efficiency": {
   "uplift_retention": "(telemetry_trigger_tool - no_repair) / (tool_on_every_task - no_repair), verified success rates",
   "invocation_fraction": "telemetry_trigger_tool invocations / 384",
   "classification": {
    "efficient": "uplift retention >= 0.80 AND invocation fraction <= 0.60 on point estimates",
    "not_established": "otherwise"
   },
   "retention_bootstrap_seed": "m33:h2:retention",
   "bootstrap_iterations": 2000
  }
 },
 "detector_reproduction_gate": {
  "min_precision": 0.8,
  "min_recall": 0.75,
  "on_failure": "stop and report before any H1/H2 claim"
 },
 "metrics_required": [
  "trigger_precision",
  "trigger_recall",
  "trigger_rate",
  "verified_success_rate_per_policy",
  "tool_invocations_per_policy",
  "decode_tokens_per_policy",
  "errors_rescued_per_policy",
  "errors_introduced_per_policy",
  "h1_bootstrap_intervals",
  "h2_uplift_retention_interval",
  "per_band_descriptives_secondary"
 ],
 "privacy": {
  "public_artifacts": "aggregate counts, metrics, intervals only",
  "private_artifacts": "operands, prompts, outputs, diagnoses, per-task labels/predictions/triggers, and all recovery traces stay gitignored",
  "traces_not_training_ready": true
 },
 "framing": "product/runtime routing evidence only; no model self-correction claim; no training dataset from tool outputs",
 "candidate_only": true,
 "production_gated": true
}
