 ],
 "privacy": {
  "public_artifacts": "aggregate counts, metrics, intervals only",
  "private_artifacts": "operands, prompts, outputs, diagnoses, per-task labels/predictions/triggers, and all recovery traces stay gitignored",
  "traces_not_training_ready": true
 },
